# FXAU app URL (no trailing slash)
APP_URL=https://crypto-bot-orcin.vercel.app

# Generate this in: Settings → Python Bridge Key
BRIDGE_KEY=

# Your MT5 account credentials (never sent to the server — stays on your PC)
MT5_LOGIN=12345678
MT5_PASSWORD=your_password_here
MT5_SERVER=Exness-MT5Real

# Trading settings
LOT_SIZE=0.01          # 0.01 = micro lot (~$0.10/pip for XAUUSD)
MAGIC_NUMBER=20250429  # unique identifier for FXAU orders in MT5
CHECK_INTERVAL=30      # seconds between strategy checks
